def split_train_test(
    df: pd.DataFrame,
    config: ExperimentConfig,
) -> Tuple[pd.DataFrame, pd.DataFrame, pd.Series, pd.Series]:
    return train_test_split(
        df[FEATURES],
        df[TARGET],
        test_size=config.test_size,
        stratify=df[TARGET],
        random_state=config.random_state,
    )


def create_federated_clients(
    x_train: pd.DataFrame,
    y_train: pd.Series,
    config: ExperimentConfig,
) -> List[Tuple[pd.DataFrame, pd.Series]]:
    splitter = StratifiedKFold(
        n_splits=config.n_clients,
        shuffle=True,
        random_state=config.random_state,
    )

    clients = []

    for _, client_index in splitter.split(x_train, y_train):
        clients.append(
            (
                x_train.iloc[client_index].copy(),
                y_train.iloc[client_index].copy(),
            )
        )

    return clients


def save_client_profiles(
    clients: Sequence[Tuple[pd.DataFrame, pd.Series]],
    output_dir: Path,
) -> None:
    rows = []

    for name, (_, y_client) in zip(CLIENT_ORDER, clients):
        counts = y_client.value_counts().sort_index()

        rows.append(
            {
                "client": name,
                "n_samples": int(len(y_client)),
                "target_0": int(counts.get(0, 0)),
                "target_1": int(counts.get(1, 0)),
                "positive_rate": float(y_client.mean()),
            }
        )

    pd.DataFrame(rows).to_csv(
        output_dir / "client_partition_profile.csv",
        index=False,
    )


def build_preprocessor() -> ColumnTransformer:
    return ColumnTransformer(
        transformers=[
            ("standard", StandardScaler(), FEATURES),
        ],
        remainder="drop",
    )


def build_model_templates(config: ExperimentConfig) -> Dict[str, BaseEstimator]:
    svm_scaler = build_preprocessor()
    mlp_scaler = build_preprocessor()

    decision_tree = DecisionTreeClassifier(
        criterion="gini",
        max_depth=None,
        min_samples_split=2,
        random_state=config.random_state,
    )

    svm = Pipeline(
        steps=[
            ("scale", svm_scaler),
            (
                "model",
                SVC(
                    kernel="rbf",
                    C=3.0,
                    gamma="scale",
                    probability=True,
                    random_state=config.random_state,
                ),
            ),
        ]
    )

    mlp = Pipeline(
        steps=[
            ("scale", mlp_scaler),
            (
                "model",
                MLPClassifier(
                    hidden_layer_sizes=(64, 32),
                    activation="relu",
                    solver="adam",
                    alpha=0.0005,
                    batch_size=32,
                    learning_rate_init=0.001,
                    max_iter=700,
                    early_stopping=True,
                    validation_fraction=0.15,
                    n_iter_no_change=25,
                    random_state=config.random_state,
                ),
            ),
        ]
    )

    return {
        "DecisionTree": decision_tree,
        "SVM": svm,
        "MLP": mlp,
    }
def train_clients(
    clients: Sequence[Tuple[pd.DataFrame, pd.Series]],
    config: ExperimentConfig,
) -> Dict[str, ClientTrainingResult]:
    templates = build_model_templates(config)
    results = {}

    for name, (x_client, y_client) in zip(CLIENT_ORDER, clients):
        LOGGER.info("Training client model: %s", name)

        model = clone(templates[name])
        start = time.perf_counter()
        model.fit(x_client, y_client)
        elapsed = time.perf_counter() - start

        results[name] = ClientTrainingResult(
            name=name,
            model=model,
            train_seconds=float(elapsed),
            n_train_samples=int(len(x_client)),
        )

        LOGGER.info("Finished %s in %.6f seconds", name, elapsed)

    return results


def model_positive_probability(
    model: BaseEstimator,
    x: pd.DataFrame,
) -> np.ndarray:
    if hasattr(model, "predict_proba"):
        return model.predict_proba(x)[:, 1]

    if hasattr(model, "decision_function"):
        raw_scores = model.decision_function(x)
        return 1.0 / (1.0 + np.exp(-raw_scores))

    return model.predict(x).astype(float)


def sample_size_weights(
    training_results: Mapping[str, ClientTrainingResult],
) -> Dict[str, float]:
    total = sum(result.n_train_samples for result in training_results.values())

    return {
        name: result.n_train_samples / total
        for name, result in training_results.items()
    }


def fedavg_probability_aggregation(
    training_results: Mapping[str, ClientTrainingResult],
    x: pd.DataFrame,
    weights: Optional[Mapping[str, float]] = None,
) -> np.ndarray:
    """
    Heterogeneous FedAvg-style probability aggregation.

    Standard FedAvg averages model parameters. That only works when clients
    share the same architecture. This study intentionally uses three different
    algorithms, so parameter averaging is not valid.

    Instead, each hospital/client keeps its data local and sends only
    probability outputs. The server aggregates those outputs using sample-size
    weights. This provides a practical heterogeneous federated ensemble.
    """

    if weights is None:
        weights = sample_size_weights(training_results)

    global_probability = np.zeros(len(x), dtype=float)

    for name, result in training_results.items():
        local_probability = model_positive_probability(result.model, x)
        global_probability += weights[name] * local_probability

    return global_probability


def threshold_probabilities(
    probabilities: np.ndarray,
    threshold: float,
) -> np.ndarray:
    return (probabilities >= threshold).astype(int)


def compute_metric_dict(
    y_true: pd.Series,
    probabilities: np.ndarray,
    threshold: float,
) -> Dict[str, float]:
    predictions = threshold_probabilities(probabilities, threshold)

    return {
        "accuracy": float(accuracy_score(y_true, predictions)),
        "precision": float(precision_score(y_true, predictions, zero_division=0)),
        "recall": float(recall_score(y_true, predictions, zero_division=0)),
        "f1": float(f1_score(y_true, predictions, zero_division=0)),
    }


def evaluate_all_models(
    training_results: Mapping[str, ClientTrainingResult],
    x_test: pd.DataFrame,
    y_test: pd.Series,
    config: ExperimentConfig,
) -> EvaluationBundle:
    probabilities = {}
    predictions = {}
    metrics = {}
    matrices = {}

    for name in CLIENT_ORDER:
        result = training_results[name]

        probabilities[name] = model_positive_probability(result.model, x_test)
        predictions[name] = threshold_probabilities(
            probabilities[name],
            config.decision_threshold,
        )
        metrics[name] = compute_metric_dict(
            y_test,
            probabilities[name],
            config.decision_threshold,
        )
        matrices[name] = confusion_matrix(y_test, predictions[name])

    probabilities["Global"] = fedavg_probability_aggregation(
        training_results,
        x_test,
    )
    predictions["Global"] = threshold_probabilities(
        probabilities["Global"],
        config.decision_threshold,
    )
    metrics["Global"] = compute_metric_dict(
        y_test,
        probabilities["Global"],
        config.decision_threshold,
    )
    matrices["Global"] = confusion_matrix(y_test, predictions["Global"])

    metrics_df = pd.DataFrame(metrics).T.loc[ALL_MODEL_ORDER]

    return EvaluationBundle(
        metrics=metrics_df,
        probabilities=probabilities,
        predictions=predictions,
        confusion_matrices=matrices,
    )


