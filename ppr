def run_experiment(
    data_path: Path,
    output_dir: Path,
    config: ExperimentConfig,
) -> EvaluationBundle:
    set_plot_style()
    output_dir = ensure_dir(output_dir)
    LOGGER.info("Writing outputs to %s", output_dir.resolve())

    df = load_heart_data(data_path)
    save_dataset_profile(df, output_dir)
    generate_eda_figures(df, output_dir)

    x_train, x_test, y_train, y_test = split_train_test(df, config)
    clients = create_federated_clients(x_train, y_train, config)
    save_client_profiles(clients, output_dir)

    training_results = train_clients(clients, config)
    bundle = evaluate_all_models(
        training_results, x_test, y_test, config
    )

    save_metric_tables(bundle, output_dir)
    generate_evaluation_figures(
        bundle, training_results, y_test, output_dir
    )
    generate_shap_outputs(
        training_results, x_train, x_test, config, output_dir
    )
    generate_lime_outputs(
        training_results, x_train, x_test, config, output_dir
    )
    generate_xai_coverage_outputs(bundle, y_test, config, output_dir)

    if config.save_models:
        save_trained_models(training_results, output_dir)

    save_summary_files(
        df, training_results, bundle, config, output_dir
    )
    LOGGER.info("Experiment complete")
    return bundle


def fraction(value: str) -> float:
    try:
        parsed = float(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError("Value must be numeric.") from exc
    if parsed <= 0 or parsed >= 1:
        raise argparse.ArgumentTypeError(
            "Value must be greater than 0 and less than 1."
        )
    return parsed


def positive_int(value: str) -> int:
    try:
        parsed = int(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError(
            "Value must be an integer."
        ) from exc
    if parsed <= 0:
        raise argparse.ArgumentTypeError(
            "Value must be a positive integer."
        )
    return parsed


def parse_coverage_values(
    values: Optional[Sequence[str]],
) -> Tuple[float, ...]:
    if not values:
        return (0.98, 1.00)
    try:
        parsed = tuple(float(value) for value in values)
    except ValueError as exc:
        raise argparse.ArgumentTypeError(
            "Coverage values must be numeric."
        ) from exc
    if any(value <= 0 or value > 1 for value in parsed):
        raise argparse.ArgumentTypeError(
            "Coverage values must be in (0, 1]."
        )
    return parsed


def parse_args(
    argv: Optional[Sequence[str]] = None,
) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Run the FedXAI-Health federated learning and explainable AI "
            "pipeline for secure medical analytics."
        )
    )
    parser.add_argument(
        "--data",
        type=Path,
        required=True,
        help="Path to the heart.csv dataset.",
    )
    parser.add_argument(
        "--output",
        type=Path,
        default=Path("fedxai_health_outputs"),
        help="Directory for figures, tables, models, and summaries.",
    )
    parser.add_argument(
        "--test-size",
        type=fraction,
        default=0.20,
        help="Central test split fraction in (0, 1).",
    )
    parser.add_argument(
        "--threshold",
        type=fraction,
        default=0.50,
        help="Positive-class decision threshold in (0, 1).",
    )
    parser.add_argument(
        "--shap-background-size",
        type=positive_int,
        default=80,
    )
    parser.add_argument(
        "--shap-sample-size",
        type=positive_int,
        default=120,
    )
    parser.add_argument(
        "--shap-nsamples",
        type=positive_int,
        default=100,
    )
    parser.add_argument(
        "--coverage",
        nargs="*",
        default=None,
        help="For example: --coverage 0.98 1.0",
    )
    parser.add_argument("--skip-shap", action="store_true")
    parser.add_argument("--skip-lime", action="store_true")
    parser.add_argument("--no-save-models", action="store_true")
    return parser.parse_args(argv)


def config_from_args(args: argparse.Namespace) -> ExperimentConfig:
    return ExperimentConfig(
        random_state=RANDOM_STATE,
        test_size=args.test_size,
        n_clients=3,
        decision_threshold=args.threshold,
        shap_background_size=args.shap_background_size,
        shap_sample_size=args.shap_sample_size,
        shap_nsamples=args.shap_nsamples,
        lime_num_features=10,
        xai_coverages=parse_coverage_values(args.coverage),
        run_shap=not args.skip_shap,
        run_lime=not args.skip_lime,
        save_models=not args.no_save_models,
    )


def print_final_console_report(
    bundle: EvaluationBundle,
    output_dir: Path,
) -> None:
    print()
    print("FedXAI-Health experiment complete.")
    print(f"Outputs saved to: {output_dir.resolve()}")
    print()
    print("Metrics:")
    print(bundle.metrics.round(3))


def main(argv: Optional[Sequence[str]] = None) -> int:
    configure_logging()
    args = parse_args(argv)
    config = config_from_args(args)

    try:
        bundle = run_experiment(
            data_path=args.data,
            output_dir=args.output,
            config=config,
        )
        print_final_console_report(bundle, args.output)
        return 0
    except Exception as exc:
        LOGGER.exception("Experiment failed: %s", exc)
        return 1


if __name__ == "__main__":
