    sample: pd.DataFrame,
    output_dir: Path,
) -> None:
    import shap

    figures_dir = ensure_dir(output_dir / "figures")

    for feature in ["ca", "cp"]:
        if feature not in sample.columns:
            continue

        shap.dependence_plot(
            feature,
            shap_values,
            sample,
            show=False,
        )

        plt.title(f"SHAP Dependence: {feature}")
        plt.tight_layout()
        plt.savefig(figures_dir / f"figure_16_shap_dependence_{feature}.png")
        plt.close()


