def generate_shap_outputs(
    training_results: Mapping[str, ClientTrainingResult],
    x_train: pd.DataFrame,
    x_test: pd.DataFrame,
    config: ExperimentConfig,
    output_dir: Path,
) -> None:
    if not config.run_shap:
        LOGGER.info("Skipping SHAP")
        return

    try:
        import shap
    except Exception as exc:
        LOGGER.warning("SHAP unavailable: %s", exc)
        write_text(output_dir / "shap_skipped.txt", f"SHAP unavailable: {exc}")
        return

    LOGGER.info("Generating SHAP explanations")

    background = shap.sample(
        x_train,
        min(config.shap_background_size, len(x_train)),
        random_state=config.random_state,
    )

    sample = x_test.iloc[: min(config.shap_sample_size, len(x_test))].copy()

    predictor = make_global_predict_proba(training_results)

    explainer = shap.KernelExplainer(
        lambda z: predictor(z)[:, 1],
        background,
    )

    raw_values = explainer.shap_values(
        sample,
        nsamples=config.shap_nsamples,
    )

    shap_values = np.asarray(raw_values)

    save_shap_feature_importance(
        shap_values,
        sample,
        output_dir,
    )

    save_shap_summary_plot(
        shap_values,
        sample,
        output_dir,
    )

    save_shap_dependence_plots(
        shap_values,
        sample,
        output_dir,
    )

    save_shap_force_plot(
        explainer.expected_value,
        shap_values,
        sample,
        output_dir,
    )

    save_shap_decision_plot(
        explainer.expected_value,
        shap_values,
        sample,
        output_dir,
    )


def generate_lime_outputs(
    training_results: Mapping[str, ClientTrainingResult],
    x_train: pd.DataFrame,
    x_test: pd.DataFrame,
    config: ExperimentConfig,
    output_dir: Path,
) -> None:
    if not config.run_lime:
        LOGGER.info("Skipping LIME")
        return

    try:
        from lime.lime_tabular import LimeTabularExplainer
    except Exception as exc:
        LOGGER.warning("LIME unavailable: %s", exc)
        write_text(output_dir / "lime_skipped.txt", f"LIME unavailable: {exc}")
        return

    LOGGER.info("Generating LIME explanation")

    predictor = make_global_predict_proba(training_results)

    explainer = LimeTabularExplainer(
        training_data=x_train.values,
        feature_names=FEATURES,
        class_names=["No disease", "Disease"],
        mode="classification",
        discretize_continuous=True,
        random_state=config.random_state,
    )

    explanation = explainer.explain_instance(
        x_test.iloc[0].values,
        predictor,
        num_features=config.lime_num_features,
    )

    explain_dir = ensure_dir(output_dir / "explainability")

    explanation.save_to_file(
        str(explain_dir / "lime_instance_0_explanation.html")
    )

    pd.DataFrame(
        explanation.as_list(),
        columns=["feature_rule", "local_weight"],
    ).to_csv(
        explain_dir / "lime_instance_0_explanation.csv",
        index=False,
    )


def evaluate_coverage_policy(
    y_test: pd.Series,
    probabilities: np.ndarray,
    coverages: Sequence[float],
    threshold: float,
) -> pd.DataFrame:
    confidence = np.abs(probabilities - 0.5) * 2.0

    rows = []

    for requested_coverage in coverages:
        quantile_value = 1.0 - requested_coverage
        confidence_threshold = np.quantile(confidence, quantile_value)

        keep_mask = confidence >= confidence_threshold
        kept_index = np.where(keep_mask)[0]

        kept_y = y_test.iloc[kept_index]
        kept_probability = probabilities[keep_mask]

        row = compute_metric_dict(
            kept_y,
            kept_probability,
            threshold,
        )

        row["requested_coverage"] = float(requested_coverage)
        row["actual_coverage"] = float(keep_mask.mean())
        row["confidence_threshold"] = float(confidence_threshold)
        row["n_decided"] = int(keep_mask.sum())
        row["n_referred"] = int((~keep_mask).sum())

        rows.append(row)

    return pd.DataFrame(rows).sort_values("actual_coverage")


def plot_xai_coverage_analysis(
    coverage_df: pd.DataFrame,
    bundle: EvaluationBundle,
    output_dir: Path,
) -> None:
    figures_dir = ensure_dir(output_dir / "figures")

    baseline_f1 = bundle.metrics.loc["Global", "f1"]
    baseline_accuracy = bundle.metrics.loc["Global", "accuracy"]
    baseline_precision = bundle.metrics.loc["Global", "precision"]

    fig, axes = plt.subplots(1, 2, figsize=(10, 4))

    axes[0].plot(
        coverage_df["actual_coverage"],
        coverage_df["f1"],
        marker="o",
        color=PALETTE["DecisionTree"],
        label="XAI policy (vary tau)",
    )

    axes[0].axhline(
        baseline_f1,
        linestyle="--",
        color=PALETTE["SVM"],
        label="Baseline F1 (Global)",
    )

    axes[0].set_title("F1 vs Coverage: XAI-informed Global vs Baseline")
    axes[0].set_xlabel("Coverage (fraction decided)")
    axes[0].set_ylabel("F1-score")
    axes[0].legend()

    axes[1].plot(
        coverage_df["actual_coverage"],
        coverage_df["accuracy"],
        marker="s",
        color=PALETTE["MLP"],
        label="Accuracy (XAI policy)",
    )

    axes[1].plot(
        coverage_df["actual_coverage"],
        coverage_df["precision"],
        marker="o",
        color=PALETTE["Global"],
        label="Precision (XAI policy)",
    )

    axes[1].axhline(
        baseline_accuracy,
        linestyle="--",
        color=PALETTE["MLP"],
        alpha=0.75,
        label="Baseline Accuracy",
    )

    axes[1].axhline(
        baseline_precision,
        linestyle="--",
        color=PALETTE["Global"],
        alpha=0.75,
        label="Baseline Precision",
    )

    axes[1].set_title("Accuracy/Precision vs Coverage")
    axes[1].set_xlabel("Coverage (fraction decided)")
    axes[1].set_ylabel("Score")
    axes[1].legend()

    plt.tight_layout()
    plt.savefig(figures_dir / "figure_19_xai_coverage_analysis.png")
    plt.close()


def generate_xai_coverage_outputs(
    bundle: EvaluationBundle,
    y_test: pd.Series,
    config: ExperimentConfig,
    output_dir: Path,
) -> None:
    LOGGER.info("Generating XAI-informed coverage analysis")

    tables_dir = ensure_dir(output_dir / "tables")

    coverage_df = evaluate_coverage_policy(
        y_test=y_test,
        probabilities=bundle.probabilities["Global"],
        coverages=config.xai_coverages,
        threshold=config.decision_threshold,
    )

    coverage_df.to_csv(
        tables_dir / "xai_coverage_policy_metrics.csv",
        index=False,
    )

    plot_xai_coverage_analysis(
        coverage_df,
        bundle,
        output_dir,
    )


