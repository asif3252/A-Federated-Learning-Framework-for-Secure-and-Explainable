def make_global_predict_proba(
    training_results: Mapping[str, ClientTrainingResult],
) -> Callable[[np.ndarray | pd.DataFrame], np.ndarray]:
    def predict_proba(x: np.ndarray | pd.DataFrame) -> np.ndarray:
        if not isinstance(x, pd.DataFrame):
            x = pd.DataFrame(x, columns=FEATURES)

        p1 = fedavg_probability_aggregation(training_results, x)

        return np.column_stack([1.0 - p1, p1])

    return predict_proba


