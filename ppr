def normalized_complexity_table(
    training_results: Mapping[str, ClientTrainingResult],
) -> pd.DataFrame:
    complexity = pd.Series(
        {
            "DecisionTree": 0.02,
            "SVM": 0.12,
            "MLP": 1.00,
        },
        name="complexity_normalized",
    )

    times = extract_training_times(training_results)
    normalized_times = times / max(times.max(), 1e-12)

    return pd.DataFrame(
        {
            "model": CLIENT_ORDER,
            "complexity_normalized": [
                float(complexity[name]) for name in CLIENT_ORDER
            ],
            "training_time_normalized": [
                float(normalized_times[name]) for name in CLIENT_ORDER
            ],
            "training_seconds": [
                float(times[name]) for name in CLIENT_ORDER
            ],
        }
    )


